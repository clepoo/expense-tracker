def seed():
    if USE_TURSO:
        import libsql_experimental as libsql
        conn = libsql.connect(database=TURSO_URL, auth_token=TURSO_TOKEN)
        conn.row_factory = sqlite3.Row
        print(f"Connected to Turso: {TURSO_URL}")
    else:
        conn = sqlite3.connect(DB_PATH)
        conn.row_factory = sqlite3.Row
        print(f"Connected to SQLite: {DB_PATH}")

    conn.executescript("""
        CREATE TABLE IF NOT EXISTS transactions (
            id INTEGER PRIMARY KEY AUTOINCREMENT, date TEXT NOT NULL,
            desc TEXT NOT NULL, category TEXT NOT NULL, total REAL NOT NULL,
            my_amt REAL NOT NULL, card TEXT NOT NULL,
            qualifying TEXT NOT NULL DEFAULT 'Yes',
            type TEXT NOT NULL DEFAULT 'expense', created_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS sales (
            id INTEGER PRIMARY KEY AUTOINCREMENT, date TEXT NOT NULL,
            desc TEXT NOT NULL, revenue REAL NOT NULL, cost REAL NOT NULL DEFAULT 0,
            profit REAL NOT NULL DEFAULT 0, created_at TEXT NOT NULL
        );
        CREATE TABLE IF NOT EXISTS recurring (
            id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT NOT NULL,
            amount REAL NOT NULL, category TEXT NOT NULL, active INTEGER NOT NULL DEFAULT 1
        );
    """)
    conn.execute("DELETE FROM transactions")
    conn.execute("DELETE FROM sales")
    conn.execute("DELETE FROM recurring")
    print("Cleared existing data.")
    now = datetime.now().isoformat()
    for t in DATA["transactions"]:
        conn.execute(
            "INSERT INTO transactions (date,desc,category,total,my_amt,card,qualifying,type,created_at) VALUES (?,?,?,?,?,?,?,?,?)",
            (t["date"],t["desc"],t["category"],t["total"],t["my_amt"],t["card"],t["qualifying"],t.get("type","expense"),now)
        )
    print(f"Inserted {len(DATA['transactions'])} transactions.")
    for s in DATA["sales"]:
        conn.execute(
            "INSERT INTO sales (date,desc,revenue,cost,profit,created_at) VALUES (?,?,?,?,?,?)",
            (s["date"],s["desc"],s["revenue"],s["cost"],s["profit"],now)
        )
    print(f"Inserted {len(DATA['sales'])} sales.")
    for r in DATA["recurring"]:
        conn.execute("INSERT INTO recurring (name,amount,category,active) VALUES (?,?,?,1)",
                     (r["name"],r["amount"],r["category"]))
    print(f"Inserted {len(DATA['recurring'])} recurring items.")
    conn.commit()
    if USE_TURSO:
        try: conn.sync()
        except Exception: pass
    conn.close()
    print("\n✅ Seed complete.")

if __name__ == "__main__":
    seed()
